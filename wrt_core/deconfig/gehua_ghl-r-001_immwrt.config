# Gehua GHL-R-001 (MT7621) - 32MB flash profile

# Target definition (managed by build.sh usually, but kept for clarity)
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_gehua_ghl-r-001=y

# Build/package format
CONFIG_USE_APK=n

# Core web and DNS
CONFIG_PACKAGE_default-settings=y
CONFIG_PACKAGE_default-settings-chn=y
CONFIG_PACKAGE_luci-app-mosdns=y
CONFIG_PACKAGE_uhttpd=y
CONFIG_PACKAGE_uhttpd-mod-ubus=y

# Essential LuCI apps
CONFIG_PACKAGE_luci-app-temp-status=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-app-wol=y

# Swap
CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_luci-app-zram=y

# Use LuCI's default bootstrap theme to save space.
CONFIG_PACKAGE_luci-theme-bootstrap=y
# CONFIG_PACKAGE_luci-theme-argon is not set

# Keep MosDNS compact. Full geoip/geosite data can easily consume several MB.
# CONFIG_PACKAGE_v2ray-geodata is not set
# CONFIG_PACKAGE_v2ray-geoip is not set
# CONFIG_PACKAGE_v2ray-geosite is not set
# CONFIG_PACKAGE_v2dat is not set

# Remove Docker and its dependencies
# CONFIG_PACKAGE_luci-app-dockerman is not set
# CONFIG_PACKAGE_luci-i18n-dockerman-zh-cn is not set
# CONFIG_PACKAGE_dockerd is not set
# CONFIG_PACKAGE_docker is not set
# CONFIG_PACKAGE_containerd is not set
# CONFIG_PACKAGE_runc is not set
# CONFIG_PACKAGE_tini is not set

# Remove proxy stacks and large applications
# CONFIG_PACKAGE_luci-app-passwall is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Haproxy is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Xray is not set
# CONFIG_PACKAGE_luci-app-ssr-plus is not set
# CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Xray is not set
# CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Socks5_Proxy is not set
# CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Socks_Server is not set
# CONFIG_PACKAGE_luci-app-openclash is not set
# CONFIG_PACKAGE_luci-app-homeproxy is not set
# CONFIG_PACKAGE_luci-app-mihomo is not set
# CONFIG_PACKAGE_luci-app-nikki is not set
# CONFIG_PACKAGE_xray-core is not set
# CONFIG_PACKAGE_sing-box is not set
# CONFIG_PACKAGE_mihomo is not set
# CONFIG_PACKAGE_haproxy is not set
# CONFIG_PACKAGE_luci-app-unblockneteasemusic is not set
# CONFIG_PACKAGE_luci-app-adguardhome is not set
# CONFIG_PACKAGE_luci-app-easytier is not set
# CONFIG_PACKAGE_luci-app-lucky is not set
# CONFIG_PACKAGE_luci-app-oaf is not set
# CONFIG_PACKAGE_luci-app-pbr is not set
# CONFIG_PACKAGE_luci-app-smartdns is not set
# CONFIG_PACKAGE_luci-app-ttyd is not set
# CONFIG_PACKAGE_luci-app-vlmcsd is not set
# CONFIG_PACKAGE_easytier is not set
# CONFIG_PACKAGE_lucky is not set
# CONFIG_PACKAGE_oaf is not set
# CONFIG_PACKAGE_open-app-filter is not set
# CONFIG_PACKAGE_smartdns is not set

# Remove file and storage services
# CONFIG_PACKAGE_luci-app-samba4 is not set
# CONFIG_PACKAGE_kmod-usb-storage is not set
# CONFIG_PACKAGE_kmod-fs-ntfs3 is not set

# Remove benchmark/debug payloads
# CONFIG_PACKAGE_coremark is not set
