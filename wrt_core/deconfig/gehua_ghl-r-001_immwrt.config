# Gehua GHL-R-001 (MT7621) - Minimal Configuration for 32MB Flash

# Target definition (managed by build.sh usually, but kept for clarity)
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_gehua_ghl-r-001=y

# Core Custom Plugins
CONFIG_PACKAGE_luci-app-ssr-plus=y
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Xray=y
CONFIG_PACKAGE_luci-app-mosdns=y

# Essential Tools
CONFIG_PACKAGE_luci-app-temp-status=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-app-wol=y
CONFIG_PACKAGE_luci-app-vlmcsd=y

# ---------------------------------------------------------
# REMOVE HEAVY PACKAGES (Override global deconfigs)
# ---------------------------------------------------------

# Remove Docker and its dependencies
# CONFIG_PACKAGE_luci-app-dockerman is not set
# CONFIG_PACKAGE_luci-i18n-dockerman-zh-cn is not set
# CONFIG_PACKAGE_dockerd is not set
# CONFIG_PACKAGE_docker is not set
# CONFIG_PACKAGE_containerd is not set
# CONFIG_PACKAGE_runc is not set
# CONFIG_PACKAGE_tini is not set

# Remove Multimedia and heavy apps
# CONFIG_PACKAGE_luci-app-unblockneteasemusic is not set
# CONFIG_PACKAGE_luci-app-adguardhome is not set
# CONFIG_PACKAGE_luci-app-easytier is not set
# CONFIG_PACKAGE_luci-app-lucky is not set

# Remove File Services (Optional, Samba is heavy)
# CONFIG_PACKAGE_luci-app-samba4 is not set

# Theme control
CONFIG_PACKAGE_luci-theme-design=y
CONFIG_PACKAGE_luci-theme-argon=y

# FS and Storage (Gehua is usually used for networking only)
# CONFIG_PACKAGE_kmod-usb-storage is not set
# CONFIG_PACKAGE_kmod-fs-ntfs3 is not set

# Swap
CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_luci-app-zram=y
