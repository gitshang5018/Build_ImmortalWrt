CONFIG_TARGET_ipq40xx=y
CONFIG_TARGET_ipq40xx_generic=y
# CONFIG_TARGET_DEVICE_ipq40xx_generic_DEVICE_8dev_habanero-dvk is not set
CONFIG_TARGET_DEVICE_ipq40xx_generic_DEVICE_p2w_r619ac-128m=y
CONFIG_TARGET_DEVICE_ipq40xx_generic_DEVICE_p2w_r619ac_128m=y
CONFIG_TARGET_DEVICE_ipq40xx_generic_DEVICE_p2w_r619ac=y
# CONFIG_TARGET_MULTI_PROFILE is not set

# Kernel modules
CONFIG_PACKAGE_kmod-tls=y
CONFIG_PACKAGE_kmod-tun=y

# Package
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_fuse-utils=y
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_sgdisk=y
CONFIG_PACKAGE_openssl-util=y
CONFIG_PACKAGE_qrencode=y

# Enable Luci App
# CONFIG_PACKAGE_luci-app-adguardhome is not set
CONFIG_PACKAGE_luci-app-autoreboot=y
# CONFIG_PACKAGE_luci-app-dockerman is not set
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_luci-app-vlmcsd=y
